<Window x:Class="DiskMonitor.AppBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Disk Monitor"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#F2F2F2"
        Height="36"
        Width="180"
        SizeToContent="Manual"
        AllowsTransparency="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Border x:Name="RootBorder" Background="#F2F2F2" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
        <StackPanel x:Name="StatusPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="10,0,12,0"
                    Cursor="Hand"
                    Background="#01000000">
            <Image x:Name="IconImage" Width="18" Height="18" Margin="0,0,6,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock x:Name="StatusText"
                       Text="…"
                       FontSize="13"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       Foreground="#1A1A1A"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
