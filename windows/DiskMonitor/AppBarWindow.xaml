<Window x:Class="DiskMonitor.AppBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Disk Monitor"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#F2F2F2"
        Height="36"
        Width="280"
        SizeToContent="Manual"
        AllowsTransparency="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Border x:Name="RootBorder" Background="#F2F2F2" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
        <DockPanel Margin="6,0,4,0" LastChildFill="True">
            <Border x:Name="MoreChip"
                    DockPanel.Dock="Right"
                    Width="32"
                    CornerRadius="4"
                    Cursor="Hand"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                <Image x:Name="MoreIcon"
                       Width="14" Height="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <!-- Clip so chips never paint over "…" -->
            <Border x:Name="ChipsClip" ClipToBounds="True">
                <StackPanel x:Name="ChipsHost"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left"/>
            </Border>
        </DockPanel>
    </Border>
</Window>
